# Gold Tier AI Employee - Environment Variables
# Copy this to .env and fill in your credentials

# ============================================================================
# EMAIL MCP SERVER
# ============================================================================

# Gmail API
GMAIL_API_KEY=your_gmail_api_key_here
GMAIL_API_SECRET=your_gmail_api_secret_here

# Outlook
OUTLOOK_TOKEN=your_outlook_token_here

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here

# ============================================================================
# SOCIAL MEDIA MCP SERVER
# ============================================================================

# Facebook
FACEBOOK_ACCESS_TOKEN=your_facebook_access_token_here
FACEBOOK_PAGE_ID=your_facebook_page_id_here

# Instagram
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token_here
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_instagram_business_account_id_here

# X (Twitter) API v2
X_API_KEY=your_x_api_key_here
X_API_SECRET=your_x_api_secret_here
X_ACCESS_TOKEN=your_x_access_token_here
X_ACCESS_TOKEN_SECRET=your_x_access_token_secret_here

# LinkedIn
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token_here
LINKEDIN_ORG_ID=your_linkedin_organization_id_here

# ============================================================================
# BROWSER MCP SERVER
# ============================================================================

BROWSER_HEADLESS=true
BROWSER_TIMEOUT=30000

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================

NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# Vault Settings
VAULT_PATH=./vault
APPROVAL_REQUIRED=true

# ============================================================================
# API KEYS & CREDENTIALS
# ============================================================================

# Application API Keys
APP_SECRET_KEY=your_app_secret_key_here
JWT_SECRET=your_jwt_secret_here

# Database (if using)
DATABASE_URL=postgresql://user:pass@localhost:5432/goldtier

# ============================================================================
# NOTES
# ============================================================================
# 1. Never commit the .env file to version control
# 2. Keep credentials secure and rotate them regularly
# 3. Use service accounts where possible instead of personal tokens
# 4. Enable 2FA on all API provider accounts
# 5. Store .env in a secure location with restricted access
